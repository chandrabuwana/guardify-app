{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter (Android)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_simple.dart",
            "deviceId": "emulator-5554",
            "args": [
                "--debug",
                "--android-skip-build-dependency-validation"
            ]
        },
        {
            "name": "Flutter (Web)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_simple.dart",
            "deviceId": "chrome",
            "args": [
                "--web-port=3000"
            ]
        },
        {
            "name": "Flutter Test App (Android)",
            "request": "launch", 
            "type": "dart",
            "program": "lib/main_test.dart",
            "deviceId": "emulator-5554"
        },
        {
            "name": "guardify-app",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "guardify-app (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "guardify-app (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}